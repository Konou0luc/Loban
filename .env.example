# Copier vers backend/.env et renseigner les valeurs.

# Neon : en cas d’erreur JDBC « cached plan must not change result type », l’app force déjà
# prepareThreshold=0 via Hikari. Tu peux aussi ajouter &prepareThreshold=0 à l’URL si besoin.
#
# Chaque ligne doit être VARIABLE=valeur (pas seulement l’URL seule sur la ligne).
# Si erreur SQL « column transporter_profile_complete does not exist », exécute
# backend/db/neon-users-columns.sql dans le SQL Editor Neon puis redémarre l’API.
DATABASE_URL=jdbc:postgresql://localhost:5432/loban
DATABASE_USER=loban
DATABASE_PASSWORD=loban

SERVER_PORT=8080
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# Origines autorisées pour CORS (séparées par des virgules, sans espace superflu).
# En prod (Vercel + Railway) : ajoute l’URL exacte du front, ex. https://loban-frontend.vercel.app
# Ne pas mettre VITE_API_URL ici : c’est une variable du front ; le back utilise CORS_ALLOWED_ORIGINS.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173

# Cloudinary — photos de profil transporteurs (https://cloudinary.com → Dashboard → API Keys)
# Dossier sur Cloudinary : loban/profiles/ (créé automatiquement à l’upload)
CLOUDINARY_ENABLED=true
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Sans Cloudinary : mettre CLOUDINARY_ENABLED=false (les images restent en data URL en base, déconseillé en prod).
